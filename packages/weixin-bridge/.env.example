# Gatehouse project root (contains .gatehouse/)
GATEHOUSE_PROJECT_DIR=/path/to/your-gatehouse-project

# OpenCode HTTP (default 4096 for bun run dev)
OPENCODE_URL=http://127.0.0.1:4096

# iLink gateway
WIXIN_ILINK_BASE_URL=https://ilinkai.weixin.qq.com

# WeChat CDN (image download/decrypt)
# WIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c

# Optional: iLink bot_type (default 3)
# WIXIN_BOT_TYPE=3

# Optional: outbound bot_agent identifier (iLink base_info telemetry)
# WIXIN_BOT_AGENT=GatehouseLead/0.1.0

# Optional: max wait for lead reply (ms, default 600000 = 10 minutes)
# LEAD_REPLY_TIMEOUT_MS=600000
