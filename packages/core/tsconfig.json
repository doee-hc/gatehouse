{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["bun-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "test/**/*.ts"]
}
