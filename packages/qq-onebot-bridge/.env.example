# Gatehouse project root (contains .gatehouse/)
GATEHOUSE_PROJECT_DIR=/path/to/your-gatehouse-project

# OpenCode HTTP (default 4096 for bun run dev)
OPENCODE_URL=http://127.0.0.1:4096

# NapCat forward WebSocket (OneBot V11)
QQ_ONEBOT_WS_URL=ws://127.0.0.1:3001

# Optional: match Access Token in NapCat WebUI network settings
# QQ_ONEBOT_ACCESS_TOKEN=

# Optional: reply only when @ mentioned (default true)
# QQ_ONEBOT_REQUIRE_AT=true

# Optional: listen to specific group IDs only, comma-separated; empty = all groups
# QQ_ONEBOT_GROUP_ALLOWLIST=123456789,987654321

# Optional: max wait for lead reply (ms, default 600000 = 10 minutes)
# LEAD_REPLY_TIMEOUT_MS=600000
