{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@gatehouse/portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build:character-sheet-json": "bun script/build-character-sheet-json.ts",
    "import:office-layout": "bun script/import-office-layout.ts",
    "dev": "bun script/portal-stack.ts start",
    "dev:ui": "bun script/portal-stack.ts ui",
    "dev:restart": "bun script/portal-stack.ts restart",
    "dev:stop": "bun script/portal-stack.ts stop",
    "demo:status-sync": "bun script/status-sync-demo.ts",
    "gallery:orchestration-graphs": "bun script/generate-orchestration-graph-gallery.ts",
    "build": "bun script/ensure-assets.ts && bun --bun vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "dompurify": "^3.4.8",
    "marked": "^17.0.1",
    "phaser": "3.87.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.9",
    "@types/bun": "^1.3.13",
    "@types/dompurify": "^3.2.0",
    "@types/qrcode": "^1.5.6",
    "@typescript/native-preview": "7.0.0-dev.20251207.1",
    "typescript": "^5.8.2",
    "vite": "^7.1.4"
  }
}
