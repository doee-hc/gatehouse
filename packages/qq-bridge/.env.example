# Gatehouse 项目根目录（含 .gatehouse/）
GATEHOUSE_PROJECT_DIR=/path/to/your-gatehouse-project

# OpenCode HTTP（bun run dev 默认 4096）
OPENCODE_URL=http://127.0.0.1:4096

# QQ 开放平台 Bot
QQ_APP_ID=
QQ_SECRET=

# 可选：是否使用沙箱环境（默认 true）
# QQ_SANDBOX=true

# 可选：等待 lead 回复的最长时间（毫秒，默认 600000 = 10 分钟）
# LEAD_REPLY_TIMEOUT_MS=600000
