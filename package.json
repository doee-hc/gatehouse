{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "gatehouse",
  "description": "Gatehouse multi-agent harness for OpenCode",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun packages/core/script/dev-opencode.ts",
    "dev:portal": "bun run --cwd packages/portal dev",
    "dev:weixin-bridge": "bun run --cwd packages/weixin-bridge dev",
    "login:weixin-bridge": "bun run --cwd packages/weixin-bridge login",
    "dev:feishu-bridge": "bun run --cwd packages/feishu-bridge dev",
    "dev:qq-bridge": "bun run --cwd packages/qq-bridge dev",
    "channels": "bun run --cwd packages/core bin/gatehouse.ts channels",
    "channels:serve": "bun run --cwd packages/core bin/gatehouse.ts channels serve",
    "build": "bun run --cwd packages/core build",
    "typecheck": "bun run --filter '@gatehouse/*' typecheck",
    "test": "bun run --filter '@gatehouse/{core,channels-core,weixin-bridge,feishu-bridge,qq-bridge}' test"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  }
}
